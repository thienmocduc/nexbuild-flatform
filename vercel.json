{
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/*.js": { "memory": 256, "maxDuration": 10 }
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "https://c-users-admin-documents-nexbuild-os-flatform-production.up.railway.app/api/v1/:path*" },
    { "source": "/health", "destination": "https://c-users-admin-documents-nexbuild-os-flatform-production.up.railway.app/health" },
    { "source": "/nexdesign", "destination": "/nexdesign-app" },
    { "source": "/nexdesign-ai", "destination": "/nexdesign-landing" }
  ],
  "redirects": [
    { "source": "/nexdesign-app.html", "destination": "/nexdesign", "permanent": true },
    { "source": "/nexdesign-landing.html", "destination": "/nexdesign-ai", "permanent": true },
    { "source": "/dashboard.html", "destination": "/dashboard", "permanent": true },
    { "source": "/marketplace.html", "destination": "/marketplace", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/lang/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
