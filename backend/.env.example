# NexBuild API Environment Variables
# Copy to .env and fill in real values

# App
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexbuild

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (generate RSA keys: openssl genrsa -out keys/private.pem 2048 && openssl rsa -in keys/private.pem -pubout -out keys/public.pem)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_SECRET_KEY=change-this-in-production

# S3 (file uploads)
S3_BUCKET=nexbuild-uploads
S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Escrow config
ESCROW_AUTO_RELEASE_DAYS=30
COMMISSION_SUPPLIER_PCT=2.5
COMMISSION_BOOKING_PCT=8.0
